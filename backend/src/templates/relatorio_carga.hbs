<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            font-size: 12px;
            color: #000;
        }
        .header-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            border: 2px solid #000;
        }
        .header-table td {
            padding: 10px;
        }
        .logo-cell {
            width: 25%;
            text-align: center;
            border-right: 2px solid #000;
        }
        .title-cell {
            width: 75%;
            text-align: center;
        }
        .title-cell h2 {
            margin: 0;
            font-size: 24px;
        }
        .logo-text {
            color: #d32f2f;
            font-size: 24px;
            font-weight: bold;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .logo-subtext {
            color: #d32f2f;
            font-size: 10px;
            margin: 0;
        }
        
        .info-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        .info-table th, .info-table td {
            border: 1px solid #000;
            padding: 8px;
            text-align: left;
        }
        .info-table th {
            width: 20%;
            background-color: #f9f9f9;
        }
        .info-table td {
            width: 30%;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
            text-align: center;
        }
        .items-table th, .items-table td {
            border: 1px solid #000;
            padding: 8px;
        }
        .items-table th {
            background-color: #9e9e9e;
            color: #000;
            font-weight: bold;
        }
        .items-table .total-row td {
            background-color: #bdbdbd;
            font-weight: bold;
        }

        .summary-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        .summary-table th, .summary-table td {
            border: 1px solid #000;
            padding: 8px;
            text-align: left;
        }
        .summary-table th {
            width: 30%;
            background-color: #9e9e9e;
            font-weight: bold;
        }
        
        .footer-table {
            width: 100%;
            border-collapse: collapse;
        }
        .footer-table th, .footer-table td {
            border: 1px solid #000;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }
        .footer-table th {
            background-color: #9e9e9e;
            font-weight: bold;
            height: 30px;
        }
        .footer-table td {
            height: 80px;
        }

        .signature-img {
            max-height: 70px;
            max-width: 200px;
            display: block;
            margin-top: 5px;
        }
    </style>
</head>
<body>

    <div style="text-align: center; margin-bottom: 10px; font-weight: bold;">
        {{dataGeracao}}
    </div>

    <table class="header-table">
        <tr>
            <td class="logo-cell">
                <div class="logo-text">
                    {{#if logoBase64}}
                    <img src="{{logoBase64}}" style="max-height: 50px; max-width: 150px;" alt="Sideral" />
                    {{else}}
                    <span style="font-size: 30px; margin-right: 5px;">🔥</span> Sideral
                    {{/if}}
                </div>
                {{#unless logoBase64}}
                <div class="logo-subtext">Fundição e Siderurgia</div>
                {{/unless}}
            </td>
            <td class="title-cell">
                <h2>Relatório de Expedição de Peças</h2>
            </td>
        </tr>
    </table>

    <table class="info-table">
        <tr>
            <th>Nome da Carga:</th>
            <td>{{Nome_Carga}}</td>
            <th>Data:</th>
            <td>{{Data}}</td>
        </tr>
        <tr>
            <th>Cliente:</th>
            <td>{{Cliente}}</td>
            <th>Veículo:</th>
            <td>{{Veiculo}}</td>
        </tr>
        <tr>
            <th>Transportadora:</th>
            <td>{{Transportadora}}</td>
            <th>Placa:</th>
            <td>{{Placa}}</td>
        </tr>
        <tr>
            <th>Hora prevista chegada:</th>
            <td>{{Hora_Prevista_Chegada}}</td>
            <th>Hora prevista saída:</th>
            <td>{{Hora_Prevista_Saida}}</td>
        </tr>
        <tr>
            <th>Hora chegada:</th>
            <td>{{Hora_Chegada}}</td>
            <th>Hora saída:</th>
            <td>{{Hora_Saida}}</td>
        </tr>
        <tr>
            <th>Responsável:</th>
            <td>{{Responsavel}}</td>
            <th>NF:</th>
            <td>{{NF}}</td>
        </tr>
        <tr>
            <th>Status:</th>
            <td>{{Status}}</td>
            <th>Faturamento:</th>
            <td>{{Faturamento}}</td>
        </tr>
    </table>

    <table class="items-table">
        <thead>
            <tr>
                <th>Cód. Olimpo</th>
                <th>Peça</th>
                <th>Quantidade de Peças</th>
                <th>Cód. Embalagem</th>
                <th>Embalagem</th>
                <th>Quantidade Rack:</th>
            </tr>
        </thead>
        <tbody>
            {{#each Pecas}}
            <tr>
                <td>{{Codigo_Olimpo}}</td>
                <td>{{Nome_Peca}}</td>
                <td>{{Quantidade}}</td>
                <td>{{Codigo_Embalagem}}</td>
                <td>{{Nome_Embalagem}}</td>
                <td>{{Quantidade_Rack}}</td>
            </tr>
            {{/each}}
            <tr class="total-row">
                <td colspan="2">Total</td>
                <td>{{Total_Pecas}}</td>
                <td colspan="2"></td>
                <td>{{Total_Rack}}</td>
            </tr>
        </tbody>
    </table>

    <table class="summary-table">
        <tr>
            <th>Peso Total de Peças:</th>
            <td>{{Peso_Total_Pecas}}</td>
        </tr>
        <tr>
            <th>Peso Total de Embalagens:</th>
            <td>{{Peso_Total_Embalagens}}</td>
        </tr>
        <tr>
            <th>Peso Total da Carga:</th>
            <td>{{Peso_Total_Carga}}</td>
        </tr>
    </table>

    <table class="footer-table">
        <tr>
            <th style="width: 50%;">Observação:</th>
            <th style="width: 50%;">Assinatura:</th>
        </tr>
        <tr>
            <td>{{Observacao}}</td>
            <td>
                {{#if AssinaturaUrl}}
                <img src="{{AssinaturaUrl}}" class="signature-img" alt="Assinatura" />
                {{/if}}
            </td>
        </tr>
    </table>

</body>
</html>
